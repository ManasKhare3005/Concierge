{
  "name": "@closing-day/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "node ../scripts/prisma-runner.cjs migrate dev --name init",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "node ../scripts/prisma-runner.cjs migrate reset --force --skip-seed && tsx src/db/seed.ts",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@closing-day/shared": "workspace:*",
    "@prisma/client": "^6.7.0",
    "axios": "^1.8.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "groq-sdk": "^0.32.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.16.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@types/pdfkit": "^0.13.8",
    "prisma": "^6.7.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
