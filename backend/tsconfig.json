{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "..",
    "outDir": "dist",
    "baseUrl": ".",
    "types": ["node"],
    "paths": {
      "@shared": ["../shared/types/index.ts"],
      "@shared/*": ["../shared/types/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "../shared/types/**/*.ts"]
}
